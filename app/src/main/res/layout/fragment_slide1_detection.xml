<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detection"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time road surface monitoring"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="20dp"/>

        <!-- Alert Banner (hidden by default) -->
        <LinearLayout
            android:id="@+id/alertBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_alert_card"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#A32D2D"
                android:gravity="center"
                android:background="@drawable/bg_circle_red"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pothole detected!"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#791F1F"/>

                <TextView
                    android:id="@+id/tvAlertForce"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Force: — m/s²"
                    android:textSize="12sp"
                    android:textColor="#A32D2D"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvStatusCircle"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:text="○"
                android:textSize="36sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_gray"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tvStatusSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Press start to begin"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Metrics Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCELERATION"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvAccelVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 m/s²"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POTHOLES"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvCountVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#A32D2D"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Detection"
            android:textSize="16sp"
            android:textColor="#EAF3DE"
            android:backgroundTint="#639922"
            android:layout_marginBottom="10dp"/>

        <!-- Stop + Reset Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Stop"
                android:textColor="#FAECE7"
                android:backgroundTint="#993C1D"
                android:enabled="false"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Reset"
                android:textColor="#1A1A2E"
                android:backgroundTint="#E0E0E0"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>